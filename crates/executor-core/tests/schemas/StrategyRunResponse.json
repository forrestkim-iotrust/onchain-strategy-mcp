{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "StrategyRunResponse",
  "description": "Response for strategy_run (Phase 3, D-08).",
  "type": "object",
  "properties": {
    "finished_at": {
      "description": "Always populated for a successful response — Phase 3 runs are\nsynchronous to completion.",
      "type": "string"
    },
    "outcome": {
      "$ref": "#/$defs/StrategyOutcome"
    },
    "run_id": {
      "description": "ULID of the run row inserted at handler start.",
      "type": "string"
    },
    "started_at": {
      "type": "string"
    },
    "status": {
      "description": "Terminal status — Phase 3 returns only on terminal status (Succeeded\nfor normal flow; Failed paths surface as MCP errors instead).",
      "$ref": "#/$defs/RunStatus"
    },
    "strategy_id": {
      "description": "Echo of the requested strategy id.",
      "type": "string"
    }
  },
  "required": [
    "run_id",
    "strategy_id",
    "status",
    "started_at",
    "finished_at",
    "outcome"
  ],
  "$defs": {
    "Action": {
      "description": "Phase-4 action wire schema. The discriminator field is `kind`\n(snake_case), and every Phase-4 variant struct rejects unknown fields.",
      "oneOf": [
        {
          "description": "Phase-3 sentinel — strategy returned `[]`-equivalent intent.",
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "noop"
            }
          },
          "required": [
            "kind"
          ]
        },
        {
          "description": "CTX-05: ABI-driven contract call.",
          "type": "object",
          "properties": {
            "abi": {
              "type": "string"
            },
            "address": {
              "type": "string"
            },
            "args": {
              "type": "array",
              "items": true
            },
            "function": {
              "type": "string"
            },
            "kind": {
              "type": "string",
              "const": "contract_call"
            },
            "value": {
              "description": "Native-coin attached to the call (decimal-string wei). Defaults to\n`\"0\"`. Phase 5 owns transaction-level fields beyond this.",
              "type": "string",
              "default": "0"
            }
          },
          "additionalProperties": false,
          "required": [
            "kind",
            "address",
            "abi",
            "function",
            "args"
          ]
        },
        {
          "description": "CTX-06: pre-encoded raw calldata call.",
          "type": "object",
          "properties": {
            "address": {
              "type": "string"
            },
            "data": {
              "type": "string"
            },
            "kind": {
              "type": "string",
              "const": "raw_call"
            },
            "value": {
              "type": "string",
              "default": "0"
            }
          },
          "additionalProperties": false,
          "required": [
            "kind",
            "address",
            "data"
          ]
        },
        {
          "description": "CTX-07a: ERC20 `transfer(to, amount)`.",
          "type": "object",
          "properties": {
            "amount": {
              "type": "string"
            },
            "kind": {
              "type": "string",
              "const": "erc20_transfer"
            },
            "to": {
              "type": "string"
            },
            "token": {
              "type": "string"
            }
          },
          "additionalProperties": false,
          "required": [
            "kind",
            "token",
            "to",
            "amount"
          ]
        },
        {
          "description": "CTX-07b: ERC20 `approve(spender, amount)`.",
          "type": "object",
          "properties": {
            "amount": {
              "type": "string"
            },
            "kind": {
              "type": "string",
              "const": "erc20_approve"
            },
            "spender": {
              "type": "string"
            },
            "token": {
              "type": "string"
            }
          },
          "additionalProperties": false,
          "required": [
            "kind",
            "token",
            "spender",
            "amount"
          ]
        },
        {
          "description": "CTX-08: native-coin transfer.",
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "native_transfer"
            },
            "to": {
              "type": "string"
            },
            "value": {
              "type": "string"
            }
          },
          "additionalProperties": false,
          "required": [
            "kind",
            "to",
            "value"
          ]
        }
      ]
    },
    "RunStatus": {
      "description": "All run lifecycle states (D-05). Phase 2 emits only the first four\n(`queued`/`running`/`succeeded`/`failed`); the remaining three are\n**future-reserved** for Phase 5 (`simulation_denied`, `policy_denied`)\nand Phase 6 (`canceled`). They are declared here at Phase 2 to lock the\nagent-facing schema golden once and avoid contract churn later.",
      "oneOf": [
        {
          "type": "string",
          "enum": [
            "queued",
            "running",
            "succeeded",
            "failed"
          ]
        },
        {
          "description": "Phase 6 — cancellation pathway not yet wired.",
          "type": "string",
          "const": "canceled"
        },
        {
          "description": "Phase 5 — simulation rejection.",
          "type": "string",
          "const": "simulation_denied"
        },
        {
          "description": "Phase 5 — policy rejection.",
          "type": "string",
          "const": "policy_denied"
        }
      ]
    },
    "StrategyOutcome": {
      "description": "Outcome of a successful strategy run (D-08).",
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "noop"
            }
          },
          "required": [
            "kind"
          ]
        },
        {
          "type": "object",
          "properties": {
            "actions": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/Action"
              }
            },
            "kind": {
              "type": "string",
              "const": "actions"
            }
          },
          "required": [
            "kind",
            "actions"
          ]
        }
      ]
    }
  }
}

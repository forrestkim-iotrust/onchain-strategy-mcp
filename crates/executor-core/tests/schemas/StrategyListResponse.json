{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "StrategyListResponse",
  "description": "Response for strategy_list (D-07a).",
  "type": "object",
  "properties": {
    "strategies": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/StrategyListItem"
      }
    }
  },
  "required": [
    "strategies"
  ],
  "$defs": {
    "StrategyListItem": {
      "description": "List item — note: `source` is intentionally absent (D-07a).",
      "type": "object",
      "properties": {
        "action_names": {
          "description": "v1.10: sorted names of the bundle's `actions[*]` entries (the\nmanual-only one-shots). Empty when the bundle declared none. Lets\nlist-time consumers (UI badges, agent discovery) advertise which\n`strategy_run({action})` calls are valid without dragging the full\nJS source into the list response.",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "created_at": {
          "type": "string"
        },
        "deleted_at": {
          "type": [
            "string",
            "null"
          ]
        },
        "description": {
          "type": [
            "string",
            "null"
          ]
        },
        "lineage_id": {
          "description": "v1.8 name-anchored lineage: stable across version bumps. Optional\nfor back-compat with old clients.",
          "type": [
            "string",
            "null"
          ]
        },
        "name": {
          "type": "string"
        },
        "strategy_id": {
          "type": "string"
        },
        "tags": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          }
        },
        "version": {
          "description": "v1.8: 1-based version of this row within its lineage.",
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "minimum": 0
        }
      },
      "required": [
        "strategy_id",
        "name",
        "created_at"
      ]
    }
  }
}

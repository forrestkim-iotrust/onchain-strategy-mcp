{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "StrategyOutcome",
  "description": "Outcome of a successful strategy run (D-08).",
  "oneOf": [
    {
      "type": "object",
      "properties": {
        "kind": {
          "type": "string",
          "const": "noop"
        }
      },
      "required": [
        "kind"
      ]
    },
    {
      "type": "object",
      "properties": {
        "actions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Action"
          }
        },
        "kind": {
          "type": "string",
          "const": "actions"
        }
      },
      "required": [
        "kind",
        "actions"
      ]
    }
  ],
  "$defs": {
    "Action": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "noop"
            }
          },
          "required": [
            "kind"
          ]
        }
      ]
    }
  }
}
